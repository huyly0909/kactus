{
    "makefile.configureOnOpen": false,
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    "python.terminal.activateEnvironment": true,
    
    // Hide specified directories from the explorer
    "files.exclude": {
        "**/__pycache__": true,
        "**/.idea": true,
        "**/.history": true,
        "**/.pytest_cache": true,
        "**/.DS_Store": true,
        "**/*.pyc": true
    },
    
    // Hide these from search results
    "search.exclude": {
        "**/__pycache__": true,
        "**/.idea": true,
        "**/.history": true,
        "**/.pytest_cache": true
    }
}
